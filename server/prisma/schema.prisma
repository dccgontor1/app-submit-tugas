generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GURU
}

model Akun {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  nama      String   
  password  String    
  role      Role      @default(GURU)
  createdAt DateTime  @default(now())
}

// ── Master Data Siswa (diisi dari Excel, acuan permanen) ─────────────────
enum StatusTugas {
  MENUNGGU     // baru dikumpulkan, belum dinilai
  DINILAI      // sudah ada nilai dari guru
  DIKEMBALIKAN // dikembalikan ke siswa untuk revisi
}

model Siswa {
  stambuk   String    @id           // Nomor induk unik sebagai primary key
  noAbsen   Int
  nama      String
  kelas     String
  daerah    String    @default("")
  rayon     String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sesiAktif SesiAktif[]
  tugas     Tugas[]
}

model Tugas {
  id          Int         @id @default(autoincrement())
  nama        String
  kelas       String
  noAbsen     Int
  stambuk     String?
  token       String      @unique
  filePaths   String[]    // Array untuk mendukung banyak file
  submittedAt DateTime    @default(now())
  
  nilai       Float?      // nullable, diisi guru nanti
  catatan     String?     // komentar/feedback dari guru
  pemeriksa   String?     // Nama guru yang menilai
  dinilaiAt   DateTime?   // kapan dinilai
  status      StatusTugas @default(MENUNGGU)

  ujianId     String?
  ujian       Ujian?      @relation(fields: [ujianId], references: [id])
  siswa       Siswa?      @relation(fields: [stambuk], references: [stambuk])

  @@index([noAbsen])
  @@index([stambuk])
}

model Ujian {
  id          String        @id @default("")
  judul       String
  deskripsi   String?
  formatFile  String[]      // ["pdf", "docx", "jpg", "png"]
  durasi      Int           // dalam menit
  kriteria    Json?         // Array of { label: string, skor: number }
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  sesiAktif   SesiAktif[]
  tugas       Tugas[] 
}

model SesiAktif {
  token       String    @id
  nama        String
  kelas       String
  noAbsen     Int
  stambuk     String?
  deadline    DateTime
  startedAt   DateTime?
  loggedInAt  DateTime?

  ujianId     String
  ujian       Ujian     @relation(fields: [ujianId], references: [id])
  siswa       Siswa?    @relation(fields: [stambuk], references: [stambuk])

  @@unique([ujianId, stambuk])
}
